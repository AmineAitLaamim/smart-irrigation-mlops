# =============================================================================
# Smart Irrigation System — .gitignore
# =============================================================================

# Environment — never commit real secrets
.env

# Python
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
.venv/
venv/
env/
*.egg
dist/
build/
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage

# Node / Next.js
node_modules/
.next/
out/
*.tsbuildinfo
.pnp
.pnp.js
npm-debug.log*

# Docker
.docker/
.dockerignore

# ML artifacts — tracked via MLflow, not git
*.pkl
*.joblib
*.json.gz
*.json.bak
models/
mlruns/
artifacts/

# Airflow
airflow/logs/
airflow/plugins/

# Editors
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Backups
backups/
*.dump
*.sql.gz

# Qwen Code
.qwen/
QWEN.md
TASKS_DEVOPS.md

# PDFs
project_pdfs/
*.pdf
docs/PDF_SPECIFICATIONS.txt
