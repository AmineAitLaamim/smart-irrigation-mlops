# =============================================================================
# Smart Irrigation System — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in real values before running:
#   cp .env.example .env
#
# .env is gitignored — never commit real secrets.
# =============================================================================
# Services → Environment Variables Reference
# =============================================================================
#
# Service                    | Variables consumed
# -------------------------- | --------------------------------------------------
# data-ingestion             | DATABASE_URL, DB_POOL_MIN_SIZE, DB_POOL_MAX_SIZE,
#                            | REDIS_URL, REDIS_CHANNEL_SENSOR_DATA,
#                            | REDIS_CHANNEL_INGESTION_PROCESSED, DATA_INGESTION_PORT
# sensor-simulator           | REDIS_URL, SENSOR_PUBLISH_INTERVAL,
#                            | REDIS_CHANNEL_SENSOR_DATA
# feature-engineering        | DATABASE_URL, DB_POOL_MIN_SIZE, DB_POOL_MAX_SIZE,
#                            | REDIS_URL, REDIS_CHANNEL_INGESTION_PROCESSED,
#                            | REDIS_CHANNEL_FEATURES_COMPUTED
# model-server               | MLFLOW_TRACKING_URI, MLFLOW_S3_ENDPOINT_URL,
#                            | AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY,
#                            | MODEL_SERVER_GRPC_PORT, MODEL_SERVER_REST_PORT,
#                            | MLFLOW_PRODUCTION_STAGE
# drift-monitor              | DATABASE_URL, REDIS_URL, MLFLOW_TRACKING_URI,
#                            | REDIS_CHANNEL_ALERTS_ANOMALY
# irrigation-controller      | DATABASE_URL, REDIS_URL,
#                            | REDIS_CHANNEL_PREDICTIONS_NEW,
#                            | REDIS_CHANNEL_IRRIGATION_TRIGGERED
# api-gateway                | API_GATEWAY_PORT, RATE_LIMIT_PER_MIN,
#                            | CORS_ALLOWED_ORIGINS, JWT_SECRET_KEY, JWT_ALGORITHM,
#                            | JWT_ACCESS_EXPIRE_MIN, USER_SERVICE_URL,
#                            | MODEL_SERVER_REST_URL, DRIFT_MONITOR_URL,
#                            | NOTIFICATION_SERVICE_URL,
#                            | DATA_INGESTION_HEALTH_URL
# user-service               | DATABASE_URL, DB_POOL_MIN_SIZE, DB_POOL_MAX_SIZE,
#                            | REDIS_URL, REDIS_TOKEN_BLACKLIST_URL,
#                            | JWT_SECRET_KEY, JWT_ALGORITHM, JWT_ACCESS_EXPIRE_MIN,
#                            | JWT_REFRESH_EXPIRE_DAYS, BCRYPT_ROUNDS,
#                            | AUTH_MAX_ATTEMPTS, AUTH_LOCKOUT_MINUTES,
#                            | USER_SERVICE_PORT
# notification-service       | REDIS_URL, REDIS_CHANNEL_ALERTS_ANOMALY,
#                            | SMTP_FROM_ADDRESS, SMTP_PORT, SMTP_PASSWORD,
#                            | NOTIFICATION_WEBHOOK_URL, ALERT_SEVERITY_THRESHOLD
# web-dashboard              | NEXT_PUBLIC_API_BASE_URL,
#                            | NEXT_PUBLIC_POLLING_INTERVAL_MS, DASHBOARD_PORT
# prometheus                 | PROMETHEUS_SCRAPE_INTERVAL
# grafana                    | GRAFANA_ADMIN_USER, GRAFANA_ADMIN_PASSWORD
# alertmanager               | ALERTMANAGER_SMTP_HOST, ALERTMANAGER_SMTP_PORT,
#                            | ALERTMANAGER_SMTP_FROM, ALERTMANAGER_SMTP_USERNAME,
#                            | ALERTMANAGER_SMTP_PASSWORD, ALERTMANAGER_EMAIL_TO
# airflow                    | AIRFLOW__CORE__FERNET_KEY, AIRFLOW__CORE__EXECUTOR,
#                            | AIRFLOW__DATABASE__SQL_ALCHEMY_CONN,
#                            | AIRFLOW__WEBSERVER__SECRET_KEY,
#                            | AIRFLOW_ADMIN_USER, AIRFLOW_ADMIN_PASSWORD
# minio                      | MINIO_ROOT_USER, MINIO_ROOT_PASSWORD
# mlflow                     | MLFLOW_TRACKING_URI, MLFLOW_S3_ENDPOINT_URL,
#                            | AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY,
#                            | MLFLOW_ARTIFACT_BUCKET
# jenkins                    | JENKINS_ADMIN_USER, JENKINS_ADMIN_PASSWORD,
#                            | JENKINS_PORT
# timescaledb (init)         | POSTGRES_USER, POSTGRES_PASSWORD, POSTGRES_DB,
#                            | TIMESCALEDB_SENSOR_CHUNK_INTERVAL,
#                            | TIMESCALEDB_IRRIGATION_CHUNK_INTERVAL
# redis                      | REDIS_MAX_MEMORY, REDIS_EVICTION_POLICY
# =============================================================================
# Owner: DevOps (DO-10)
# =============================================================================


# =============================================================================
# DATABASE — TimescaleDB (PostgreSQL 16)
# Used by: data-ingestion, feature-engineering, model-server, user-service,
#          irrigation-controller, drift-monitor, api-gateway
# =============================================================================

POSTGRES_USER=irrigation_user
POSTGRES_PASSWORD=changeme
POSTGRES_DB=irrigation_db

# Full asyncpg connection string used by Python services
DATABASE_URL=postgresql://irrigation_user:changeme@timescaledb:5432/irrigation_db

# Hypertable chunk intervals — controls TimescaleDB time partitioning
# sensor_readings: 1 day (high write volume)
# irrigation_events: 1 week (low write volume)
TIMESCALEDB_SENSOR_CHUNK_INTERVAL="1 day"
TIMESCALEDB_IRRIGATION_CHUNK_INTERVAL="1 week"

# asyncpg connection pool size per service
DB_POOL_MIN_SIZE=2
DB_POOL_MAX_SIZE=10


# =============================================================================
# REDIS — message broker + cache
# Used by: sensor-simulator, data-ingestion, feature-engineering, model-server,
#          user-service, api-gateway, notification-service
# =============================================================================

REDIS_URL=redis://redis:6379/0

# Redis memory limit and eviction policy (set in redis.conf or command args)
REDIS_MAX_MEMORY=256mb
REDIS_EVICTION_POLICY=allkeys-lru


# =============================================================================
# AUTH / JWT
# Used by: user-service, api-gateway
# =============================================================================

# !! CHANGE THIS — must be a long random string in production
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=changeme-use-openssl-rand-hex-32

JWT_ALGORITHM=HS256

# Access token lifetime in minutes (default: 15)
JWT_ACCESS_EXPIRE_MIN=15

# Refresh token lifetime in days (default: 7)
JWT_REFRESH_EXPIRE_DAYS=7

# bcrypt hashing rounds — use 12 in production, 4 locally for faster tests
BCRYPT_ROUNDS=12

# Redis DB index used for token blacklist (keep separate from main DB index)
REDIS_TOKEN_BLACKLIST_URL=redis://redis:6379/1

# Max failed login attempts before lockout
AUTH_MAX_ATTEMPTS=5

# Lockout duration in minutes after too many failed attempts
AUTH_LOCKOUT_MINUTES=15


# =============================================================================
# API GATEWAY
# Used by: api-gateway
# =============================================================================

# Port the gateway listens on externally
API_GATEWAY_PORT=8080

# Requests per minute per IP before rate limiting kicks in
RATE_LIMIT_PER_MIN=100

# Comma-separated allowed origins for CORS (dashboard URL)
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Internal service URLs — gateway proxies requests to these
USER_SERVICE_URL=http://user-service:5005
MODEL_SERVER_REST_URL=http://model-server:8501
DRIFT_MONITOR_URL=http://drift-monitor:8002
NOTIFICATION_SERVICE_URL=http://notification-service:8003
DATA_INGESTION_HEALTH_URL=http://data-ingestion:8001/health


# =============================================================================
# ML INFRA — MLflow + MinIO
# Used by: model-server, feature-engineering, airflow, drift-monitor
# =============================================================================

MLFLOW_TRACKING_URI=http://mlflow:5000

# Points MLflow at local MinIO instead of real AWS S3
MLFLOW_S3_ENDPOINT_URL=http://minio:9000
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=changeme

# MLflow artifact bucket name in MinIO
MLFLOW_ARTIFACT_BUCKET=mlflow-artifacts

# MinIO root credentials
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme

# MLflow model registry stage that triggers hot-reload in model-server
MLFLOW_PRODUCTION_STAGE=Production


# =============================================================================
# AIRFLOW — workflow orchestration
# Used by: airflow
# =============================================================================

# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__CORE__FERNET_KEY=changeme-generate-with-fernet

AIRFLOW__CORE__EXECUTOR=LocalExecutor
# Note: airflow_db is created separately by 00_create_databases.sh — not part of the main migrations
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://irrigation_user:changeme@timescaledb:5432/airflow_db
AIRFLOW__WEBSERVER__SECRET_KEY=changeme

# Airflow admin credentials (first-run setup)
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=changeme


# =============================================================================
# DATA PIPELINE
# Used by: sensor-simulator, data-ingestion
# =============================================================================

# Seconds between sensor readings published to Redis
SENSOR_PUBLISH_INTERVAL=30

# Redis Pub/Sub channels (do not change without updating all consumers)
REDIS_CHANNEL_SENSOR_DATA=sensor:data
REDIS_CHANNEL_INGESTION_PROCESSED=ingestion:processed
REDIS_CHANNEL_FEATURES_COMPUTED=features:computed
REDIS_CHANNEL_PREDICTIONS_NEW=predictions:new
REDIS_CHANNEL_ALERTS_ANOMALY=alerts:anomaly
REDIS_CHANNEL_IRRIGATION_TRIGGERED=irrigation:triggered

# Port for data-ingestion health check endpoint
DATA_INGESTION_PORT=8001


# =============================================================================
# MODEL SERVER
# Used by: model-server
# =============================================================================

# gRPC port (internal, used by irrigation-controller)
MODEL_SERVER_GRPC_PORT=5001

# REST port (used by api-gateway)
MODEL_SERVER_REST_PORT=8501


# =============================================================================
# USER SERVICE
# Used by: user-service
# =============================================================================

USER_SERVICE_PORT=5005


# =============================================================================
# WEB DASHBOARD
# Used by: web-dashboard
# =============================================================================

# Internal port (proxied through api-gateway at /dashboard/*)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
DASHBOARD_PORT=3000

# Polling interval in milliseconds for sensor/prediction charts
NEXT_PUBLIC_POLLING_INTERVAL_MS=10000


# =============================================================================
# MONITORING — Prometheus + Grafana + Alertmanager
# Used by: prometheus, grafana, alertmanager
# =============================================================================

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme

# How often Prometheus scrapes each service's /metrics endpoint
PROMETHEUS_SCRAPE_INTERVAL=15s

# SMTP config for Alertmanager email alerts
ALERTMANAGER_SMTP_HOST=smtp.example.com
ALERTMANAGER_SMTP_PORT=587
ALERTMANAGER_SMTP_FROM=alerts@smart-irrigation.local
ALERTMANAGER_SMTP_USERNAME=changeme
ALERTMANAGER_SMTP_PASSWORD=changeme

# Alert recipient
ALERTMANAGER_EMAIL_TO=team@smart-irrigation.local


# =============================================================================
# NOTIFICATION SERVICE
# Used by: notification-service
# =============================================================================

SMTP_FROM_ADDRESS=notifications@smart-irrigation.local
SMTP_PORT=587
SMTP_PASSWORD=changeme

# Optional webhook endpoint for anomaly/irrigation alerts (leave blank to disable)
NOTIFICATION_WEBHOOK_URL=

# Minimum severity level to trigger a notification (info | warning | critical)
ALERT_SEVERITY_THRESHOLD=warning


# =============================================================================
# JENKINS — CI/CD
# Used by: jenkins
# =============================================================================

JENKINS_ADMIN_USER=admin
JENKINS_ADMIN_PASSWORD=changeme
JENKINS_PORT=8081


# =============================================================================
# ENVIRONMENT FLAG
# =============================================================================

# Set to "production" when deploying — enables stricter security checks
ENV=development
